<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <import resource="spring-app.xml"/>
    <import resource="spring-db.xml"/>

    <bean id="cacheManager" class="org.springframework.cache.support.NoOpCacheManager"/>

    <bean class="org.springframework.beans.factory.config.PropertyOverrideConfigurer">
        <property name="ignoreInvalidKeys" value="true"/>
        <property name="properties">
            <props>
                <prop key="entityManagerFactory.jpaPropertyMap[hibernate.cache.use_second_level_cache]">false</prop>
            </props>
        </property>
    </bean>
</beans>